{
  "name": "blackwall-eliza-guardrail",
  "version": "0.2.0",
  "description": "BLACK_WALL pre-action guardrail for ElizaOS agents. Wraps every action handler with a forecast() check so STOP-rated actions abort before they run; gateCall() adds per-call gating for multi-step handlers.",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "check": "node --check src/index.mjs",
    "test": "node smoke-test.mjs",
    "prepare": "git config core.hooksPath .githooks",
    "secrets:scan": "gitleaks git --no-banner --config .gitleaks.toml"
  },
  "keywords": [
    "elizaos",
    "eliza-plugin",
    "ai-agents",
    "guardrails",
    "ai-safety",
    "blackwall"
  ],
  "license": "MIT",
  "dependencies": {
    "blackwall-mcp": "^1.2.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
